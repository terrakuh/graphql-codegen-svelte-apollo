{
	"include": [
		"src"
	],
	"exclude": [
		"**/*.test.ts"
	],
	"compilerOptions": {
		"module": "commonjs",
		"target": "esnext",
		"lib": [
			"ESNext"
		],
		"declaration": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"outDir": "dist",
		"rootDir": "src",
		"types": ["node"]
	}
}
